<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:root="using:SabreToolsStudio"
             x:Class="SabreToolsStudio.Views.Controls.PathListEditor"
             DragDrop.AllowDrop="True">

    <DockPanel>
        <TextBlock DockPanel.Dock="Bottom" Name="WarningHint" FontSize="12" Foreground="#E8A33D"
                   TextWrapping="Wrap" Margin="0,8,0,0" IsVisible="False"/>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,0,0,10">
            <Button Grid.Column="0" Name="AddFilesButton" Click="OnAddFilesClick" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{x:Static root:Icons.FileDocument}" Width="13" Height="13"/>
                    <TextBlock Text="Add Files"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Name="AddFolderButton" Click="OnAddFolderClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{x:Static root:Icons.FolderPlus}" Width="13" Height="13"/>
                    <TextBlock Text="Add Folder"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="2" Name="DropHint" Classes="subtle" Text="or drag &amp; drop here"
                       FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0"/>
            <Button Grid.Column="3" Name="RemoveButton" Click="OnRemoveClick" Margin="0,0,8,0"
                    ToolTip.Tip="Remove the selected entry from the list">
                <TextBlock Text="Remove"/>
            </Button>
            <Button Grid.Column="4" Name="ClearButton" Click="OnClearClick"
                    ToolTip.Tip="Remove all entries from the list">
                <TextBlock Text="Clear"/>
            </Button>
        </Grid>

        <Panel>
            <ListBox Name="PathsList" Background="Transparent" MinHeight="80">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type x:String}">
                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" FontSize="13"
                                   ToolTip.Tip="{Binding}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Name="EmptyHint" Classes="subtle"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="12"/>
        </Panel>
    </DockPanel>
</UserControl>
