<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SabreToolsStudio.ViewModels"
        xmlns:pages="using:SabreToolsStudio.Views.Pages"
        xmlns:controls="using:SabreToolsStudio.Views.Controls"
        xmlns:root="using:SabreToolsStudio"
        x:Class="SabreToolsStudio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SabreTools Studio"
        Width="1600" Height="900"
        MinWidth="1280" MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppContentBackground}">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <pages:StatisticsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <pages:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <pages:PlaceholderView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- Main area: nav rail + page content -->
        <Grid Grid.Row="0" ColumnDefinitions="232,*">

            <!-- Navigation rail -->
            <Border Grid.Column="0"
                    Background="{DynamicResource AppRailBackground}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="20,20,20,8">
                        <TextBlock Text="SabreTools" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="STUDIO" FontSize="11" FontWeight="SemiBold" LetterSpacing="3"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,12">
                        <TextBlock Classes="navGroup" Text="ADVANCED"/>
                        <ItemsControl ItemsSource="{Binding AdvancedNav}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavItemViewModel}">
                                    <RadioButton Theme="{StaticResource NavItemTheme}" GroupName="Nav"
                                                 IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                 Command="{Binding SelectCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <PathIcon Data="{Binding Icon}" Width="15" Height="15"/>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Margin="10,8,10,0">
                        <TextBlock Classes="navGroup" Text="FEATURES"/>
                        <ItemsControl ItemsSource="{Binding PrimaryNav}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavItemViewModel}">
                                    <RadioButton Theme="{StaticResource NavItemTheme}" GroupName="Nav"
                                                 IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                 Command="{Binding SelectCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <PathIcon Data="{Binding Icon}" Width="15" Height="15"/>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
        </Grid>

        <!-- Sliding log drawer -->
        <controls:LogDrawer Grid.Row="1" DataContext="{Binding LogDrawer}"/>

        <!-- Command bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource AppBarBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Command" VerticalAlignment="Center"
                           FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource AppSubtleTextBrush}" Margin="0,0,12,0"/>

                <Border Grid.Column="1"
                        Background="{DynamicResource AppLogBackground}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <SelectableTextBlock Text="{Binding CommandPreview}"
                                             FontFamily="Cascadia Mono,Consolas,DejaVu Sans Mono,Liberation Mono,monospace"
                                             FontSize="12" VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Border>

                <Button Grid.Column="2" Classes="icon" Name="CopyCommandButton"
                        Click="OnCopyCommandClick" IsEnabled="{Binding HasCommand}"
                        ToolTip.Tip="Copy the assembled command line to the clipboard"
                        Margin="0,0,8,0" VerticalAlignment="Center">
                    <PathIcon Data="{x:Static root:Icons.ContentCopy}" Width="14" Height="14"/>
                </Button>

                <Button Grid.Column="3" Command="{Binding CancelRunCommand}"
                        IsVisible="{Binding IsRunning}"
                        ToolTip.Tip="Stop the running operation"
                        Margin="0,0,8,0" VerticalAlignment="Center" Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{x:Static root:Icons.Stop}" Width="12" Height="12"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Command="{Binding RunCommand}"
                        Classes="accent"
                        ToolTip.Tip="Run the assembled command"
                        VerticalAlignment="Center" Padding="20,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{x:Static root:Icons.Play}" Width="12" Height="12"/>
                        <TextBlock Text="Run" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
