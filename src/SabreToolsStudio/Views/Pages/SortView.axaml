<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SabreToolsStudio.ViewModels"
             xmlns:controls="using:SabreToolsStudio.Views.Controls"
             x:Class="SabreToolsStudio.Views.Pages.SortView"
             x:DataType="vm:SortViewModel">

    <DockPanel Margin="28,24,28,16">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,24,0">
                <TextBlock Classes="pageTitle" Text="{Binding Title}"/>
                <TextBlock Classes="subtle" Text="{Binding Description}"/>
            </StackPanel>
            <controls:PresetBar Grid.Column="1" VerticalAlignment="Top"/>
        </Grid>

        <Grid ColumnDefinitions="*,20,400">

            <!-- Left: inputs + DATs -->
            <Grid Grid.Column="0" RowDefinitions="*,16,*">
                <Border Grid.Row="0" Classes="card">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="Input Folders / Files"/>
                        <controls:PathListEditor ItemsSource="{Binding Inputs}"
                                                 PickerTitle="Select folders or files to rebuild from"
                                                 EmptyText="No inputs yet. Add the folders (or files) containing the source files to rebuild."/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Classes="card">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="DATs to Rebuild Against"/>
                        <controls:PathListEditor ItemsSource="{Binding Dats}" DatFilesOnly="True"
                                                 PickerTitle="Select DAT files"
                                                 EmptyText="No DATs yet. Add DAT files (or folders of DATs) describing the desired sets."/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right: options (scrolls only when the window is too short to fit) -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
            <StackPanel Spacing="16">

                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="Rebuild Output"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Output format" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding RebuildFormats}" SelectedItem="{Binding RebuildFormat}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip.Tip="How the rebuilt files are packaged in the output directory.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ComboOption}">
                                        <TextBlock Text="{Binding Label}" ToolTip.Tip="{Binding Description}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <Grid ColumnDefinitions="Auto,12,*" IsEnabled="{Binding IsTorrentGzipSelected}">
                            <CheckBox Grid.Column="0" IsChecked="{Binding Romba}" Content="Romba depot output"
                                      ToolTip.Tip="Requires TorrentGZ output. Write output files into a Romba-style depot structure, named by SHA-1."/>
                            <TextBox Grid.Column="2" Text="{Binding RombaDepth}" Watermark="Depth (default 4)"
                                     IsEnabled="{Binding Romba}"
                                     ToolTip.Tip="Optionally set the depth of output depots. Defaults to 4 levels deep."/>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Output directory" FontSize="12"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding OutputDir}" Watermark="Default: SabreTools folder"
                                         Margin="0,0,8,0"
                                         ToolTip.Tip="This sets an output folder to be used when the rebuilt files are created. If a path is not defined, the runtime directory is used instead."/>
                                <Button Grid.Column="1" Click="OnBrowseOutputClick" Content="Browse"
                                        ToolTip.Tip="Choose the folder where rebuilt sets will be written"/>
                            </Grid>
                        </StackPanel>
                        <CheckBox IsChecked="{Binding UpdateDat}" Content="Write fixdat of unmatched files"
                                  ToolTip.Tip="After rebuilding, a DAT of the files that could not be matched is written to the output directory."/>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="sectionHeader" Text="Scanning"/>
                        <CheckBox IsChecked="{Binding Quick}" Content="Quick scan of archives"
                                  ToolTip.Tip="Only use archive header information to get file information. Fastest option, but most archive formats only provide CRC and size, which can lead to inaccuracies."/>
                        <CheckBox IsChecked="{Binding Inverse}" Content="Inverse: rebuild files NOT in DATs"
                                  ToolTip.Tip="Use the DAT as a filter instead: all files found in the DAT are skipped and everything else is output in the selected format."/>
                        <CheckBox IsChecked="{Binding Delete}" Content="Delete fully rebuilt input files"
                                  ToolTip.Tip="Input files that were processed and fully matched are deleted from the source. Use with care: this permanently removes source files."/>
                        <CheckBox IsChecked="{Binding AddDate}" Content="Add dates to items, where possible"
                                  ToolTip.Tip="The date is appended to each file's information, standardized as yyyy/MM/dd HH:mm:ss."/>
                        <CheckBox IsChecked="{Binding Individual}" Content="Process input DATs individually"
                                  ToolTip.Tip="In cases where DATs would be processed in bulk, this processes each DAT on its own instead."/>
                        <CheckBox IsChecked="{Binding ChdsAsFiles}" Content="CHDs as files"
                                  ToolTip.Tip="Normally, CHDs would be processed using their internal hash. This forces all CHDs to be treated like regular files."/>
                        <CheckBox IsChecked="{Binding AaruFormatsAsFiles}" Content="AaruFormats as files"
                                  ToolTip.Tip="Normally, AaruFormats would be processed using their internal hash. This forces all AaruFormats to be treated like regular files."/>
                        <Grid ColumnDefinitions="Auto,12,*">
                            <CheckBox Grid.Column="0" IsChecked="{Binding UseHeaderSkipper}" Content="Header skipper"
                                      ToolTip.Tip="Use copier header skippers to determine if a file matches. Leave the name blank to try all known skippers, or enter a specific one such as fds.xml."/>
                            <TextBox Grid.Column="2" Text="{Binding HeaderSkipper}" Watermark="Name (blank = all)"
                                     IsEnabled="{Binding UseHeaderSkipper}"
                                     ToolTip.Tip="Specific copier header skipper to use, such as fds.xml. Blank means all known skippers are tried."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="Depot and Preprocessing"/>
                        <Grid ColumnDefinitions="Auto,12,*">
                            <CheckBox Grid.Column="0" IsChecked="{Binding Depot}" Content="Inputs are Romba depots"
                                      ToolTip.Tip="All input directories will be assumed to be Romba-style depots instead of plain folders."/>
                            <TextBox Grid.Column="2" Text="{Binding DepotDepth}" Watermark="Depth (default 4)"
                                     IsEnabled="{Binding Depot}"
                                     ToolTip.Tip="Optionally set the depth of input depots. Defaults to 4 levels deep."/>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="DAT merge preprocessing" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding MergeModes}" SelectedItem="{Binding MergeMode}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Preprocess the DAT into a specific merge structure (split, merged, non-merged, etc.) before rebuilding. See the Merging page of the SabreTools wiki for details.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ComboOption}">
                                        <TextBlock Text="{Binding Label}" ToolTip.Tip="{Binding Description}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
