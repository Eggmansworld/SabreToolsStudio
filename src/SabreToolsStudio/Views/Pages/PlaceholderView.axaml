<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SabreToolsStudio.ViewModels"
             x:Class="SabreToolsStudio.Views.Pages.PlaceholderView"
             x:DataType="vm:PlaceholderViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="520">
        <PathIcon Data="{Binding Icon}" Width="44" Height="44" Opacity="0.35" HorizontalAlignment="Center"/>
        <TextBlock Classes="pageTitle" Text="{Binding Title}" HorizontalAlignment="Center" TextAlignment="Center"/>
        <TextBlock Classes="subtle" Text="{Binding Description}" HorizontalAlignment="Center" TextAlignment="Center"/>
        <Border Background="{DynamicResource AppNavSelectedBrush}" CornerRadius="12" Padding="12,5"
                HorizontalAlignment="Center">
            <TextBlock Text="{Binding PlannedText}" FontSize="12"/>
        </Border>
    </StackPanel>
</UserControl>
