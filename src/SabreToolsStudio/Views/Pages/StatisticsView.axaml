<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SabreToolsStudio.ViewModels"
             xmlns:root="using:SabreToolsStudio"
             xmlns:controls="using:SabreToolsStudio.Views.Controls"
             x:Class="SabreToolsStudio.Views.Pages.StatisticsView"
             x:DataType="vm:StatisticsViewModel">

    <DockPanel Margin="28,24,28,20">

        <!-- Header: title, description, presets -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,24,0">
                <TextBlock Classes="pageTitle" Text="{Binding Title}"/>
                <TextBlock Classes="subtle" Text="{Binding Description}"/>
            </StackPanel>

            <controls:PresetBar Grid.Column="1" VerticalAlignment="Top"/>
        </Grid>

        <Grid ColumnDefinitions="*,20,360">

            <!-- Inputs -->
            <Border Grid.Column="0" Classes="card">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="Input DATs"/>
                    <controls:PathListEditor ItemsSource="{Binding Inputs}"
                                             PickerTitle="Select DAT files"
                                             EmptyText="No inputs yet. Add DAT files or folders containing DAT files."/>
                </DockPanel>
            </Border>

            <!-- Options -->
            <StackPanel Grid.Column="2" Spacing="16">

                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="sectionHeader" Text="Report Formats"/>
                        <TextBlock Classes="subtle" FontSize="12" Margin="0,0,0,10"
                                   Text="Output statistics to one or more formats. Text is used if none are selected."/>
                        <ItemsControl ItemsSource="{Binding ReportFormats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:FormatOption}">
                                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Label}"
                                              ToolTip.Tip="{Binding Description}" Margin="0,0,14,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="Output" Margin="0,0,0,0"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Report filename" FontSize="12"/>
                            <TextBox Text="{Binding Filename}" Watermark="Default: report"
                                     ToolTip.Tip="Set the filename for the output report(s). Leave blank for the default name."/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Output directory" FontSize="12"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding OutputDir}" Watermark="Default: SabreTools folder"
                                         Margin="0,0,8,0"
                                         ToolTip.Tip="This sets an output folder to be used when the files are created. If a path is not defined, the runtime directory is used instead."/>
                                <Button Grid.Column="1" Click="OnBrowseOutputClick" Content="Browse"
                                        ToolTip.Tip="Choose the folder where the report will be written"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="sectionHeader" Text="Options"/>
                        <CheckBox IsChecked="{Binding BaddumpColumn}" Content="Add baddump stats to output"
                                  ToolTip.Tip="Add a new column or field for counting the number of baddumps in the DAT."/>
                        <CheckBox IsChecked="{Binding NodumpColumn}" Content="Add nodump stats to output"
                                  ToolTip.Tip="Add a new column or field for counting the number of nodumps in the DAT."/>
                        <CheckBox IsChecked="{Binding Individual}" Content="Process input DATs individually"
                                  ToolTip.Tip="In cases where DATs would be processed in bulk, this flag allows them to be processed on their own instead of as one combined set of statistics."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
